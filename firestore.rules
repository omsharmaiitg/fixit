rules_version = '2';

// FixIt — Firestore security rules.
//
// Design tension this resolves: the app supports BOTH signed-in accounts and an
// anonymous report flow (device-cookie identity, no login). Anonymous users are
// not authenticated, so issue create/update cannot require auth without breaking
// reporting and community verification (upvotes/discussion). We therefore keep
// issues publicly writable but protect their integrity (append-only DNA, no
// deletes), and lock per-user docs to their owner.
//
// HARDENING NOTES (see bottom) — what to change once Firebase Auth is mandatory
// and the Watchtower/admin move to a privileged (Admin SDK) path.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // DNA must never shrink and its existing entries must never change.
    function dnaAppendOnly() {
      return request.resource.data.dna.size() >= resource.data.dna.size()
        && resource.data.dna.toSet().intersection(
             request.resource.data.dna.toSet()) == resource.data.dna.toSet();
    }

    // Server-recompute path: the Watchtower agent and the admin "Recalculate"
    // tool run the Firebase *client* SDK unauthenticated (no Admin credential),
    // so they can't satisfy signedIn(). They only ever touch these derived
    // fields, never community/identity data — allow exactly that set, nothing
    // more. (See HARDENING NOTES: the real fix is moving them to the Admin SDK.)
    function recomputeFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['pressureScore', 'pressureBreakdown', 'agingStatus',
                  'escalation', 'updatedAt']);
    }

    match /issues/{issueId} {
      // Public read — transparency, the feed, and the login-free dashboard.
      allow read: if true;

      // Create: reporting now requires an account (anonymous device-id writes
      // are gone). Field-level ownership isn't enforced here — any signed-in
      // user may create — which is fine for the hackathon scope.
      allow create: if signedIn();

      // Update: community actions (upvote / can't-find / verify / discussion /
      // adopt / device→uid backfill) require login; the unauthenticated server
      // recompute path is allowed only when it touches the derived field set.
      // DNA history stays immutable in both cases; the doc can never be deleted.
      allow update: if dnaAppendOnly() && (signedIn() || recomputeFieldsOnly());

      allow delete: if false; // issues are a permanent public record
    }

    match /users/{userId} {
      // A user's profile doc is private to that user.
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Per-user notifications (issue acknowledged, etc.). Readable only by the
    // recipient; any signed-in user may create them (an authority acting on an
    // issue notifies the reporter/adopters). Owner may mark them read.
    match /notifications/{id} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Intelligence + community collections written by the server path
    // (Watchtower / admin tools) and the seed. Currently open to write because
    // the Watchtower runs the Firebase *client* SDK unauthenticated server-side
    // (no Admin credential). See hardening notes.
    match /problemZones/{zoneId} {
      allow read: if true;
      allow write: if true;
    }
    match /squads/{squadId} {
      allow read: if true;
      allow write: if true;
    }
    match /hotspots/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /reports/{id} {
      allow read: if true;
      allow write: if true;
    }
  }
}

// ─── HARDENING NOTES ─────────────────────────────────────────────────────────
// When auth becomes mandatory and a privileged server path exists:
//  1. issues create  → `if signedIn()`  (drop anonymous reporting).
//  2. issues update  → `if signedIn() && dnaAppendOnly()`, and ideally split
//     owner-only fields (title/severity) from community fields (upvoteCount,
//     discussion, dna) with per-field checks.
//  3. problemZones / hotspots / reports / squads → move writes to the Firebase
//     Admin SDK (service account) and set `allow write: if false` here, OR gate
//     on a custom `request.auth.token.admin == true` claim. The Watchtower must
//     then authenticate (Admin SDK) instead of using the client SDK.
